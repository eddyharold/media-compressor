{
  "name": "harorudo/media-compressor",
  "description": "A Laravel utility for compressing images, PDFs, and files - powered by Intervention Image and Ghostscript",
  "type": "library",
  "require": {
    "php": "^8.2",
    "intervention/image": "^2.7",
    "illuminate/support": "^10.0|^11.0|^12.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0|^10.0",
    "pestphp/pest": "^2.0|^3.0",
    "phpstan/phpstan": "^1.11"
  },
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Harorudo\\MediaCompressor\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Harorudo\\MediaCompressor\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/pest",
    "analyse": "vendor/bin/phpstan analyse"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Harorudo\\MediaCompressor\\CompressionServiceProvider"
      ],
      "aliases": {
        "Compression": "Harorudo\\MediaCompressor\\Facades\\Compression"
      }
    }
  },
  "authors": [
    {
      "name": "Eddy Harold",
      "email": "harorudo.dev@gmail.com"
    }
  ],
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable"
}
